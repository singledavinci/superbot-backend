# SuperBot Production Environment Variables

# =======================
# Backend API & Discord
# =======================
PORT=3000
DISCORD_TOKEN=your_production_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DASHBOARD_URL=http://your_vps_ip_address  # Used for OAuth Redirects
JWT_SECRET=generate_a_long_random_string_here
# Public HTTPS origin of this API (no trailing slash). Preferred for Discord OAuth redirect_uri.
PUBLIC_API_URL=https://your-api-host.example
VITE_API_URL=http://your_vps_ip_address    # Legacy alias for PUBLIC_API_URL; also used for dashboard build

# =======================
# Database Passwords (MUST CHANGE)
# =======================
POSTGRES_USER=superbot_admin
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_DB=superbot_prod
CLICKHOUSE_PASSWORD=your_secure_clickhouse_password_here

# Prisma Database Connection
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public

# Redis Connection
REDIS_URL=redis://redis:6379/0

# =======================
# Blockchain RPC Nodes (Ethereum-only deployment)
# =======================
WSS_RPC_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# HTTPS_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# Optional comma-separated extra endpoints (merged with the URLs above; no secrets in VCS):
# WSS_RPC_URLS=wss://example-a.example,wss://example-b.example
# HTTPS_RPC_URLS=https://example-a.example,https://example-b.example
# To re-enable multi-chain support, set the following and re-add the chains
# in apps/indexer/src/index.ts and apps/worker/src/index.ts:
# POLYGON_WSS_RPC_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# BASE_WSS_RPC_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Third-Party Analytics
RESERVOIR_API_KEY=optional_reservoir_key_here

# =======================
# Mint Execution Engine (separate SERVICE_TYPE=mint-engine)
# =======================
MINT_ENGINE_PORT=3847
MINT_ENGINE_URL=http://mint-engine:3847
MINT_ENGINE_RPC_URL=
# Prepare-only beta proof: docs/smoke-mint-preflight.md, docs/mint-smoke-production.md
# npm run db:identity  npm run db:migrate  npm run db:verify-mint  npm run seed:mint-smoke  npm run smoke:mint-preflight
# SMOKE_GUILD_DISCORD_ID=  SMOKE_USER_DISCORD_ID=  (operator Discord snowflakes matching DB)
MINT_ENGINE_SERVICE_SECRET=rotate_this_shared_secret_between_executor_and_engine
MINT_API_NONCE_REDIS_TTL_SEC=180
MINT_API_MAX_CLOCK_SKEW_SEC=60
MINT_EXECUTION_ENABLED=false
MINT_MAINNET_BROADCAST_ENABLED=false
# Production prepare-only path: use prepare + keep execution/broadcast off.
MINT_ENGINE_MODE=prepare
MINT_REQUIRE_SECURE_SIGNER=true
MINT_DEFAULT_CHAIN_ID=1
MINT_TESTNET_ONLY=true
MINT_EMERGENCY_STOP=false
MINT_INTELLIGENCE_BOT_EXECUTION_COMMANDS=false
MINT_COPY_PENDING_ENABLED=false
MINT_ALLOW_PRIVATE_RELAY=false
MINT_COPY_CONFIRMED_ENABLED=false
# Dedicated Discord application token for apps/mint-executor-bot (do not reuse main DISCORD_TOKEN).
MINT_EXECUTOR_DISCORD_TOKEN=
# OAuth2 "Client ID" for the Supermint application — optional but strongly recommended so slash commands never register if the wrong token is used.
# MINT_EXECUTOR_DISCORD_APPLICATION_ID=
# MINT_EXECUTOR_REGISTER_SLASH_COMMANDS=true

# Optional: Discord guild (server) snowflake. When set, slash commands are also registered on this guild for instant updates while testing (global commands can lag ~up to 1h).
# MINT_EXECUTOR_GUILD_ID=
# When MINT_EXECUTOR_GUILD_ID is set, global slash commands are skipped by default to avoid duplicate /mint-* entries (guild vs global). Set to true only if you intentionally want both:
# MINT_EXECUTOR_REGISTER_GLOBAL_COMMANDS=true
# Never set real private keys in production.env or committed files.
MINT_LOCAL_DEV_PRIVATE_KEY=
MINT_TESTNET_LIVE_VERIFIED_AT=

# Mint Executor Bot (SERVICE_TYPE=mint-executor-bot) — separate Discord application; see docs/mint-deployment.md

# OpenSea (drop resolution for SeaDrop)
# OPENSEA_API_KEY=
