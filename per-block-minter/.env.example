# ═══════════════════════════════════════════════════════════════════════════════
# Per-Block Minter — Environment Configuration
# Copy to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════════

# ---- Wallets ----
# 12/24-word HD seed phrase. Wallets are derived sequentially.
MNEMONIC=

# Optional: comma-separated 0x-prefixed private keys (used in addition to HD wallets)
IMPORTED_KEYS=

# ---- Network ----
# Primary HTTP RPC URL (required)
PROVIDER_URL=

# WebSocket RPC URL for fastest block detection (optional but recommended)
WS_RPC_URL=

# ---- Target Contract ----
# The NFT contract to mint from
TARGET_CONTRACT=0x460d7dfa7aefb52ddb7b87a767485325b31272d9

# ---- Mint Settings ----
# Mint price per NFT in ETH (set to 0 for free mints)
MINT_PRICE_ETH=0

# NFTs each wallet mints per block
MINT_QTY_PER_WALLET=1

# Wallets to fire per block (0 = auto-calculate to fill 18/block cap)
WALLETS_PER_BLOCK=0

# Total NFTs to mint (0 = unlimited, keep going until MAX_BLOCKS)
TOTAL_MINT_TARGET=0

# Max blocks to attempt before stopping
MAX_BLOCKS=50

# ---- Mint Function ----
# Auto-detect the mint function by simulating against the contract
AUTO_DETECT_SELECTOR=true

# Fallback selector if auto-detect fails
# Common: 0xa0712d68=mint(uint256), 0x1249c58b=mint(), 0x40c10f19=mint(address,uint256)
MINT_SELECTOR=0xa0712d68

# ---- Gas (aggressive for block inclusion) ----
BLOCK_MINT_MAX_FEE_GWEI=100
BLOCK_MINT_PRIORITY_FEE_GWEI=10
BLOCK_MINT_GAS_LIMIT=300000

# ---- Timing ----
# Delay after block event before firing (ms). 0 = immediate.
BLOCK_FIRE_DELAY_MS=0

# Cooldown between blocks (ms)
INTER_BLOCK_COOLDOWN_MS=1000
