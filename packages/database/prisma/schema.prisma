// SuperBot Prisma Schema
// learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Core Multi-Tenant Models ---

model Guild {
  id              String             @id @default(uuid())
  discordId       String             @unique  // Discord Guild (Server) ID
  name            String
  planTier        String             @default("FREE")
  settings        Json?
  alertChannels   AlertChannel[]
  trackedWallets  TrackedWallet[]
  trackedCollections TrackedCollection[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model User {
  id                  String      @id @default(uuid())
  discordId           String      @unique
  walletAddress       String?     // Primary linked wallet
  encryptedPrivateKey String?     // Generated sub-wallet for sniping
  autoMintEnabled     Boolean     @default(false)
  maxMintPrice        Float       @default(0.1)
  gasBufferGwei       Float       @default(5.0)
  globalPremiumStatus Boolean     @default(false)
  watchlists          Watchlist[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

// --- Alert Infrastructure ---

model AlertChannel {
  id               String          @id @default(uuid())
  guildId          String
  discordChannelId String          // Discord Channel ID (snowflake)
  name             String
  alertType        String          // e.g. WHALE_BUY | WHALE_SALE | MINT_RADAR
  mentionRoleId    String?         // Discord Role ID to ping
  guild            Guild           @relation(fields: [guildId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([guildId, alertType])
}

// --- Tracking Models ---

model TrackedWallet {
  id               String    @id @default(uuid())
  guildId          String
  address          String
  label            String?
  alertChannelId   String?               // Discord channel ID (string, not FK)
  mentionRoleId    String?               // Discord Role ID to ping
  smartMoneyScore  Float?
  winRate          Float?
  totalFlips       Int?
  guild            Guild     @relation(fields: [guildId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([address, guildId])           // Per-guild tracking (same wallet, multiple servers)
}

model TrackedCollection {
  id                      String    @id @default(uuid())
  guildId                 String
  contractAddress         String
  name                    String
  chain                   String    @default("ethereum")
  floorAlertPct           Float?                // Alert when floor drops by this %
  floorRiseAlertPct       Float?                // Alert when floor rises by this %
  sweepThresholdNative    Float?                // Min total ETH (native) for sweep alerts
  massListingThreshold    Int?                  // Min listings in window for surge alerts
  hotMintEnabled          Boolean               @default(true)
  hotMintChannelId        String?
  delistAlertEnabled      Boolean               @default(true)
  delistChannelId         String?
  alertChannelId          String?               // Discord channel ID (string, not FK)
  mentionRoleId           String?               // Discord Role ID to ping
  guild                   Guild     @relation(fields: [guildId], references: [id])
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@unique([contractAddress, guildId])
}

model Watchlist {
  id            String   @id @default(uuid())
  userId        String
  targetType    String   // "wallet" or "collection"
  targetAddress String
  user          User     @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())

  @@unique([userId, targetType, targetAddress])
}

model SyncState {
  chain     String   @id
  lastBlock Int
  updatedAt DateTime @updatedAt
}

// --- Alert delivery / idempotency ---

model AlertDeliveryLog {
  id          String   @id @default(uuid())
  deliveryKey String   @unique  // e.g. `${eventId}:${channelId}` ensures one delivery per route
  eventId     String
  channelId   String
  alertType   String
  status      String              // "delivered" | "failed" | "skipped_duplicate"
  error       String?
  createdAt   DateTime @default(now())

  @@index([eventId])
  @@index([createdAt])
}
