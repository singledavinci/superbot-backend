// SuperBot Prisma Schema
// learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Core Multi-Tenant Models ---

model Guild {
  id              String             @id @default(uuid())
  discordId       String             @unique  // Discord Guild (Server) ID
  name            String
  planTier        String             @default("FREE")
  settings        Json?
  alertChannels   AlertChannel[]
  trackedWallets  TrackedWallet[]
  trackedCollections TrackedCollection[]
  mintJobs                 MintJob[]
  copyMintConfigs          CopyMintConfig[]
  mintWalletAuthorizations MintWalletAuthorization[]
  mainnetExecutionApprovals MainnetExecutionApproval[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model User {
  id                  String      @id @default(uuid())
  discordId           String      @unique
  walletAddress       String?     // Primary linked wallet
  encryptedPrivateKey String?     // Generated sub-wallet for sniping
  autoMintEnabled     Boolean     @default(false)
  maxMintPrice        Float       @default(0.1)
  gasBufferGwei       Float       @default(5.0)
  globalPremiumStatus Boolean     @default(false)
  watchlists          Watchlist[]
  mintWallets          MintWallet[]
  mintWalletAuthGrants MintWalletAuthorization[]
  copyMintConfigsOwned CopyMintConfig[]
  mintJobs             MintJob[]
  mainnetExecutionApprovals MainnetExecutionApproval[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

// --- Alert Infrastructure ---

model AlertChannel {
  id               String          @id @default(uuid())
  guildId          String
  discordChannelId String          // Discord Channel ID (snowflake)
  name             String
  alertType        String          // e.g. WHALE_BUY | WHALE_SALE | MINT_RADAR
  mentionRoleId    String?         // Discord Role ID to ping
  guild            Guild           @relation(fields: [guildId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([guildId, alertType])
}

// --- Tracking Models ---

model TrackedWallet {
  id               String    @id @default(uuid())
  guildId          String
  address          String
  label            String?
  alertChannelId   String?               // Discord channel ID (string, not FK)
  mentionRoleId    String?               // Discord Role ID to ping
  smartMoneyScore  Float?
  winRate          Float?
  totalFlips       Int?
  guild            Guild     @relation(fields: [guildId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([address, guildId])           // Per-guild tracking (same wallet, multiple servers)
}

model TrackedCollection {
  id                      String    @id @default(uuid())
  guildId                 String
  contractAddress         String
  name                    String
  chain                   String    @default("ethereum")
  floorAlertPct           Float?                // Alert when floor drops by this %
  floorRiseAlertPct       Float?                // Alert when floor rises by this %
  sweepThresholdNative    Float?                // Min total ETH (native) for sweep alerts
  massListingThreshold    Int?                  // Min listings in window for surge alerts
  hotMintEnabled          Boolean               @default(true)
  hotMintChannelId        String?
  delistAlertEnabled      Boolean               @default(true)
  delistChannelId         String?
  alertChannelId          String?               // Discord channel ID (string, not FK)
  mentionRoleId           String?               // Discord Role ID to ping
  guild                   Guild     @relation(fields: [guildId], references: [id])
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@unique([contractAddress, guildId])
}

model Watchlist {
  id            String   @id @default(uuid())
  userId        String
  targetType    String   // "wallet" or "collection"
  targetAddress String
  user          User     @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())

  @@unique([userId, targetType, targetAddress])
}

model SyncState {
  chain     String   @id
  lastBlock Int
  updatedAt DateTime @updatedAt
}

// --- Alert delivery / idempotency ---

model AlertDeliveryLog {
  id          String   @id @default(uuid())
  deliveryKey String   @unique  // e.g. `${eventId}:${channelId}` ensures one delivery per route
  eventId     String
  channelId   String
  alertType   String
  status      String              // "delivered" | "failed" | "skipped_duplicate"
  error       String?
  createdAt   DateTime @default(now())

  @@index([eventId])
  @@index([createdAt])
}

// --- Mint Execution Engine ---

model MintWallet {
  id                   String   @id @default(uuid())
  userId               String
  label                String?
  chainId              Int
  address              String   // normalized lowercase 0x…
  signerType           String   // simulation-only | external-signer | vault-signer | local-dev-signer
  signerReference      String?  // opaque ref to vault/HSM; never a raw key
  isExecutionEnabled   Boolean  @default(false)
  maxFeePerGas         String?
  maxPriorityFeePerGas String?
  maxTotalCostNative   String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id])
  authorizations       MintWalletAuthorization[]
  mintJobs             MintJob[]
  copyMintConfigs      CopyMintConfig[]
  mainnetExecutionApprovals MainnetExecutionApproval[]

  @@index([userId, chainId])
  @@index([address, chainId])
}

model MintWalletAuthorization {
  id           String    @id @default(uuid())
  guildId      String
  userId       String
  mintWalletId String
  grantedBy    String?
  grantedAt    DateTime  @default(now())
  revokedAt    DateTime?
  permissions  String[]  @default([]) // e.g. preflight, prepare, schedule, live
  guild        Guild     @relation(fields: [guildId], references: [id])
  user         User      @relation(fields: [userId], references: [id])
  mintWallet   MintWallet @relation(fields: [mintWalletId], references: [id], onDelete: Cascade)

  @@index([guildId, userId, mintWalletId])
}

model CopyMintConfig {
  id                       String   @id @default(uuid())
  guildId                  String
  userId                   String
  trackedWalletAddress     String
  targetCollectionAddress  String?
  mode                     String   // confirmed_only | pending_if_visible
  executionWalletId      String
  quantity                 Int      @default(1)
  maxFeePerGas             String?
  maxPriorityFeePerGas     String?
  maxTotalCostNative       String?
  executionModeDefault     String   @default("simulation")
  enabled                  Boolean  @default(false)
  label                    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  guild                    Guild    @relation(fields: [guildId], references: [id])
  user                     User     @relation(fields: [userId], references: [id])
  executionWallet          MintWallet @relation(fields: [executionWalletId], references: [id])

  @@index([guildId, userId])
}

model MintJob {
  id                   String    @id @default(uuid())
  guildId              String
  userId               String
  walletId             String
  chainId              Int
  collectionAddress    String
  mintContract         String
  dropSource           String
  dropType             String
  triggerType          String
  executionMode        String
  status               String
  quantity             Int       @default(1)
  scheduledAt          DateTime?
  startTime            DateTime?
  maxFeePerGas         String?
  maxPriorityFeePerGas String?
  maxTotalCostNative   String?
  txHash               String?
  errorCode            String?
  errorMessage         String?
  planHash             String?
  simulationStatus     String?
  executionStartedAt   DateTime?
  submittedAt          DateTime?
  confirmedAt          DateTime?
  metadataJson         Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  guild                Guild     @relation(fields: [guildId], references: [id])
  user                 User      @relation(fields: [userId], references: [id])
  wallet               MintWallet @relation(fields: [walletId], references: [id])
  nonceLocks           NonceLock[]
  transactions         MintTransaction[]
  simulations          MintSimulation[]
  auditLogs            MintAuditLog[]

  @@index([guildId, status, scheduledAt])
  @@index([planHash])
  @@index([userId])
}

model MintDrop {
  id                  String    @id @default(uuid())
  chainId             Int
  collectionAddress   String
  mintContract        String
  source              String
  dropType            String
  startTime           DateTime?
  endTime             DateTime?
  priceNative           String?
  maxPerWallet        Int?
  maxSupply           Int?
  stageId             String?
  merkleRoot          String?
  requiresProof       Boolean   @default(false)
  requiresSignature   Boolean   @default(false)
  status              String    @default("unknown")
  resolvedAt          DateTime?
  metadataJson        Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([chainId, mintContract])
}

model NonceLock {
  id            String    @id @default(uuid())
  chainId       Int
  walletAddress String    // lowercase
  nonce         String    // decimal string for bigint safety
  status        String
  mintJobId     String
  lockedAt      DateTime  @default(now())
  releasedAt    DateTime?
  metadataJson  Json?
  mintJob       MintJob   @relation(fields: [mintJobId], references: [id], onDelete: Cascade)

  @@index([chainId, walletAddress])
  @@index([mintJobId])
}

model MintTransaction {
  id                    String    @id @default(uuid())
  mintJobId             String
  chainId               Int
  walletAddress         String
  nonce                 String
  to                    String
  value                 String
  calldataHash          String
  txHash                String?
  status                String
  providerResponsesJson Json?
  gasStrategyJson       Json?
  createdAt             DateTime  @default(now())
  submittedAt           DateTime?
  confirmedAt           DateTime?
  metadataJson          Json?
  mintJob               MintJob   @relation(fields: [mintJobId], references: [id], onDelete: Cascade)

  @@index([mintJobId])
  @@index([txHash])
}

model MintSimulation {
  id          String   @id @default(uuid())
  mintJobId   String
  status      String
  result      String?
  gasEstimate String?
  revertReason String?
  checkedAt   DateTime @default(now())
  metadataJson Json?
  mintJob     MintJob  @relation(fields: [mintJobId], references: [id], onDelete: Cascade)

  @@index([mintJobId])
}

model MintAuditLog {
  id           String   @id @default(uuid())
  mintJobId    String?
  guildId      String?
  userId       String?
  action         String
  status         String?
  message        String?
  metadataJson Json?
  createdAt    DateTime @default(now())
  mintJob      MintJob? @relation(fields: [mintJobId], references: [id], onDelete: SetNull)

  @@index([mintJobId])
  @@index([guildId, createdAt])
}

model TrackedMintTrigger {
  id               String   @id @default(uuid())
  chainId          Int
  trackedWallet    String
  collectionAddress String
  txHash           String
  triggerSource    String
  detectedAt       DateTime @default(now())
  usedForMint      Boolean  @default(false)
  metadataJson     Json?

  @@index([trackedWallet, chainId])
  @@index([txHash])
}

model MintProviderHealth {
  id            String    @id @default(uuid())
  providerName  String
  providerType  String
  chainId       Int
  status        String
  latencyMs     Int?
  errorCount    Int       @default(0)
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  metadataJson  Json?
  updatedAt     DateTime  @updatedAt

  @@unique([providerName, chainId])
}

model MintMainnetReadiness {
  id                 String    @id @default("default")
  checklistJson      Json      @default("{}")
  testnetVerifiedAt  DateTime?
  updatedAt          DateTime  @updatedAt
}

/** Singleton row: operator emergency stop (OR with env MINT_EMERGENCY_STOP). */
model MintEngineRuntimeState {
  id            String   @id @default("default")
  emergencyStop Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  metadataJson  Json?
}

/**
 * Explicit per-wallet mainnet execution approval with caps and expiry.
 * Default: no row → mainnet live blocked even if env flags allow.
 */
model MainnetExecutionApproval {
  id                   String    @id @default(uuid())
  userId               String
  guildId              String
  mintWalletId         String
  walletAddress        String
  chainId              Int       @default(1)
  approvedBy           String    @default("")
  approvalStatus       String    @default("active")
  maxFeePerGas         String?
  maxPriorityFeePerGas String?
  maxTotalCostNative   String?
  maxQuantity          Int       @default(1)
  allowedCollections   Json?
  expiresAt            DateTime
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  metadataJson         Json?
  guild                Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mintWallet           MintWallet @relation(fields: [mintWalletId], references: [id], onDelete: Cascade)

  @@index([guildId, userId, mintWalletId, approvalStatus])
  @@index([expiresAt])
}
