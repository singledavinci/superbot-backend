// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Guild {
  id             String          @id // Discord Guild ID
  name           String
  ownerId        String
  planTier       String          @default("FREE")
  settings       Json?
  alertChannels  AlertChannel[]
  alertRules     AlertRule[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model User {
  id                   String      @id // Discord User ID
  walletAddress        String?
  globalPremiumStatus  Boolean     @default(false)
  watchlists           Watchlist[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

model AlertChannel {
  id         String     @id @default(uuid())
  guildId    String
  channelId  String     // Discord Channel ID
  purpose    String     // e.g., "whale-watch", "nft-sales"
  rolesToPing String[]  // Array of Discord Role IDs
  guild      Guild      @relation(fields: [guildId], references: [id])
  alertRules AlertRule[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([guildId, channelId])
}

model TrackedWallet {
  id                     String      @id @default(uuid())
  address                String      @unique
  label                  String?
  globalSmartMoneyScore  Float?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  alertRules             AlertRule[]
}

model TrackedCollection {
  id              String      @id @default(uuid())
  contractAddress String      @unique
  slug            String?
  chain           String      @default("ethereum")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  alertRules      AlertRule[]
}

model AlertRule {
  id                  String             @id @default(uuid())
  guildId             String
  channelId           String
  type                String             // "wallet_buy", "floor_drop", etc.
  targetWalletId      String?
  targetCollectionId  String?
  threshold           Float?             // e.g., 0.5 ETH for floor_drop
  isActive            Boolean            @default(true)
  
  guild               Guild              @relation(fields: [guildId], references: [id])
  channel             AlertChannel       @relation(fields: [channelId], references: [id])
  wallet              TrackedWallet?     @relation(fields: [targetWalletId], references: [id])
  collection          TrackedCollection? @relation(fields: [targetCollectionId], references: [id])

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model Watchlist {
  id            String   @id @default(uuid())
  userId        String
  targetType    String   // "wallet" or "collection"
  targetAddress String
  user          User     @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())

  @@unique([userId, targetType, targetAddress])
}
