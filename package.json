{
  "name": "nft-intelligence-bot",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node dist/src/index.js",
    "start:bot": "node scripts/run-service.cjs bot",
    "start:indexer": "node scripts/run-service.cjs indexer",
    "start:worker": "node scripts/run-service.cjs worker",
    "start:api": "node scripts/run-service.cjs api",
    "start:market-indexer": "node scripts/run-service.cjs market-indexer",
    "start:floor-worker": "node scripts/run-service.cjs floor-worker",
    "start:mint-engine": "node scripts/run-service.cjs mint-engine",
    "start:mint-executor-bot": "node scripts/run-service.cjs mint-executor-bot",
    "build": "npx prisma generate --schema=packages/database/prisma/schema.prisma && node scripts/clean-dist.cjs && tsc && node scripts/verify-mint-engine-dist.cjs",
    "db:identity": "node --require ts-node/register/transpile-only scripts/db-identity-check.ts",
    "db:verify-mint": "node --require ts-node/register/transpile-only scripts/verify-mint-tables.ts",
    "db:migrate": "node scripts/prisma-migrate-deploy.cjs",
    "seed:mint-smoke": "node --require ts-node/register/transpile-only scripts/seed-mint-smoke.ts",
    "smoke:mint-preflight": "node --require ts-node/register/transpile-only scripts/smoke-mint-preflight.ts",
    "test": "node --test --require ts-node/register/transpile-only packages/analytics/src/__tests__/opportunityScoring.test.ts apps/bot/src/__tests__/opportunityEmbed.test.ts packages/intelligence/src/__tests__/contextual-intelligence.test.ts packages/analytics/src/__tests__/NFTMetadata.test.ts packages/analytics/src/__tests__/CollectionNameResolver.test.ts packages/analytics/src/__tests__/NftNameResolver.test.ts packages/analytics/src/__tests__/WalletActionBatcher.test.ts apps/mint-engine/src/__tests__/serviceHmac.test.ts apps/mint-engine/src/__tests__/phase3.test.ts apps/mint-engine/src/__tests__/mainnetBetaGates.test.ts apps/mint-engine/src/__tests__/mainnetApprovalQueries.test.ts apps/mint-engine/src/__tests__/emergencyRuntime.test.ts apps/mint-engine/src/__tests__/mainnetSingleFlight.test.ts apps/mint-engine/src/__tests__/mainnetDryRunCreateJob.test.ts apps/mint-engine/src/__tests__/mainnetLiveCreateJob.test.ts apps/mint-engine/src/__tests__/mintRoutesConfirmMainnet.test.ts apps/mint-engine/src/__tests__/preflightBlockReason.test.ts apps/mint-engine/src/__tests__/mintJobPreflightPersist.test.ts apps/mint-engine/src/__tests__/liveExecutionPolicy.test.ts apps/mint-engine/src/__tests__/mintEngineHealthPayload.test.ts apps/mint-executor-bot/src/__tests__/mintEmbeds.test.ts apps/mint-executor-bot/src/__tests__/mintStatusDisplay.test.ts apps/mint-executor-bot/src/__tests__/mintStatusEnv.test.ts apps/mint-executor-bot/src/__tests__/mintHttpAuth.test.ts apps/mint-executor-bot/src/__tests__/mintExecutorCommandLoader.test.ts",
    "lint": "node -e \"console.log('No eslint config in repo'); process.exit(0)\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@clickhouse/client": "^1.18.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/node": "^25.6.0",
    "axios": "^1.16.0",
    "bullmq": "^5.76.5",
    "cors": "^2.8.6",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0"
  }
}
