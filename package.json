{
  "name": "nft-intelligence-bot",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node dist/src/index.js",
    "start:bot": "SERVICE_TYPE=bot node dist/src/index.js",
    "start:indexer": "SERVICE_TYPE=indexer node dist/src/index.js",
    "start:worker": "SERVICE_TYPE=worker node dist/src/index.js",
    "start:api": "SERVICE_TYPE=api node dist/src/index.js",
    "start:market-indexer": "SERVICE_TYPE=market-indexer node dist/src/index.js",
    "start:floor-worker": "SERVICE_TYPE=floor-worker node dist/src/index.js",
    "build": "prisma generate --schema=packages/database/prisma/schema.prisma && tsc",
    "test": "node --test --require ts-node/register/transpile-only packages/analytics/src/__tests__/opportunityScoring.test.ts apps/bot/src/__tests__/opportunityEmbed.test.ts packages/intelligence/src/__tests__/contextual-intelligence.test.ts packages/analytics/src/__tests__/NFTMetadata.test.ts packages/analytics/src/__tests__/CollectionNameResolver.test.ts packages/analytics/src/__tests__/NftNameResolver.test.ts packages/analytics/src/__tests__/WalletActionBatcher.test.ts",
    "lint": "node -e \"console.log('No eslint config in repo'); process.exit(0)\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@clickhouse/client": "^1.18.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/node": "^25.6.0",
    "axios": "^1.16.0",
    "bullmq": "^5.76.5",
    "cors": "^2.8.6",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0"
  }
}
